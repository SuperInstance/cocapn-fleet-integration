# BreederDaemonV2 Environment Template
# Copy to /etc/cocapn/breeder.env and fill in real values.

# ---------------------------------------------------------------------------
# Fleet Identity
# ---------------------------------------------------------------------------
FLEET_NAME=Cocapn
NODE_ID=kimi1
ENVIRONMENT=production

# ---------------------------------------------------------------------------
# Plato / Sunset Endpoints
# ---------------------------------------------------------------------------
PLATO_URL=http://plato.internal:8848
SUNSET_API_URL=http://sunset.internal:8080
TILES_URL=http://tiles.internal:8847
FLUX_VECTOR_URL=http://flux.internal:9001
CONSENSUS_URL=http://consensus.internal:9002
METRONOME_URL=http://metronome.internal:9003

# ---------------------------------------------------------------------------
# Breeding Loop Parameters
# ---------------------------------------------------------------------------
BREED_INTERVAL_SECONDS=300
MAX_CONCURRENT_BREEDS=4
AGENT_LIFETIME_SECONDS=3600
THERMAL_BUDGET_PCT=80.0
SUNSET_THRESHOLD=0.3

# ---------------------------------------------------------------------------
# Circuit Breaker Config
# ---------------------------------------------------------------------------
CB_SERVICES_YAML=/opt/cocapn/fleet_circuit_breaker/services.yaml

# ---------------------------------------------------------------------------
# Metrics & Observability
# ---------------------------------------------------------------------------
METRICS_PORT=9090
METRICS_PATH=/metrics
LOG_LEVEL=INFO
PROMETHEUS_PUSH_GATEWAY=

# ---------------------------------------------------------------------------
# Git Integration (for agent shells)
# ---------------------------------------------------------------------------
GIT_BASE_URL=https://github.com/SuperInstance
GIT_TOKEN=
AGENT_SHELL_REPO_TEMPLATE=agent-shell-{agent_id}

# ---------------------------------------------------------------------------
# Database / State
# ---------------------------------------------------------------------------
STATE_DIR=/var/lib/cocapn/breeder
CHECKPOINT_INTERVAL_SECONDS=60

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------
ENABLE_HOT_SWAP=true
ENABLE_AB_TEST=true
ENABLE_AUTO_ROLLBACK=true
