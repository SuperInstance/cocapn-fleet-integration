{
  "dashboard": {
    "id": null,
    "title": "Fleet Overview",
    "tags": ["fleet", "overview"],
    "timezone": "UTC",
    "panels": [
      {
        "id": 1,
        "title": "Service Health Status",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=~\"fleet-.*\"}",
            "legendFormat": "{{job}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Breeding Cycle Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(breeding_cycles_total[5m])",
            "legendFormat": "cycles/sec"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Thermal Budget Usage",
        "type": "gauge",
        "targets": [
          {
            "expr": "thermal_budget_used_pct",
            "legendFormat": "usage %"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Active Agents",
        "type": "stat",
        "targets": [
          {
            "expr": "active_agents",
            "legendFormat": "agents"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 5,
        "title": "Circuit Breaker State",
        "type": "table",
        "targets": [
          {
            "expr": "circuit_breaker_state",
            "legendFormat": "{{service}}"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16}
      }
    ]
  }
}
